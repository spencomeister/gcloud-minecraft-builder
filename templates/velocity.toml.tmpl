# Velocity configuration generated by gcloud-minecraft-builder

config-version = "2.7"

# The number of players allowed to be online at once.
player-info-forwarding-mode = "modern"

# What should we display for the maximum number of players?
show-max-players = 500

# Should we authenticate players with Mojang?
online-mode = true

# Should we enable the built-in HAPROXY protocol support?
accepts-transfers = false

# Prevent client proxy connections? Requires online-mode.
force-key-authentication = true

# If enabled, player IP addresses will be logged.
announce-proxy-commands = true

# Whether to log command executions.
log-command-executions = false

# Whether to log player connections.
log-player-connections = true

# The secret the proxy uses to ensure backends are the only servers connecting.
[advanced]
compression-threshold = 256
compression-level = -1
login-ratelimit = 3000
connection-timeout = 5000
read-timeout = 30000
haproxy-protocol = false
tcp-fast-open = false
bungee-plugin-message-channel = true
show-ping-requests = false
failover-on-unexpected-server-disconnect = true
announce-proxy-commands = true
send-player-info-forwarding-mode = true

[query]
enabled = false
port = 25577
map = "Velocity"
show-plugins = false

# Secret shared between Velocity and Paper
[forwarding]
secret-file = "forwarding.secret"

[[servers]]
name = "{{SERVER_NAME}}"
address = "127.0.0.1:25565"

[try]
servers = ["{{SERVER_NAME}}"]

[security]
forwarding-secret = "{{VELOCITY_SECRET}}"
